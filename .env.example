# Pariscope frontend environment (Vite)
# Copy to .env and fill in. Only VITE_-prefixed vars are exposed to the client.
# The publishable/anon key is safe for the browser; never put service-role keys here.

# Preferred for Lovable-hosted production:
# Lovable Cloud can overwrite VITE_SUPABASE_* while Cloud is attached, so use
# these external aliases for the production Supabase project.
VITE_EXTERNAL_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_EXTERNAL_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLISHABLE_KEY
VITE_EXTERNAL_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Fallback names used outside Lovable Cloud-managed projects.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_PUBLISHABLE_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_USE_CANONICAL=false

# --- Server-side only (set in Supabase Edge Function secrets, NOT here) ---
# SUPABASE_SERVICE_ROLE_KEY=...   # bypasses RLS — never expose to client
# RENTCAST_API_KEY=...
# LOVABLE_API_KEY=...
# WEBHOOK_SECRET=...              # shared secret for seed-review / taggbox-webhook
